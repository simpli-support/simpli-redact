APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8014
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins, or "*" to allow all.
CORS_ORIGINS=*

# LLM provider — litellm supports OpenAI, Azure OpenAI, Anthropic, Gemini,
# OpenRouter, Ollama, and 100+ other providers.
# See: https://docs.litellm.ai/docs/providers
LITELLM_MODEL=openai/gpt-5-mini
# LITELLM_MODEL=azure/gpt-4o
# LITELLM_MODEL=anthropic/claude-sonnet-4-20250514
# LITELLM_MODEL=gemini/gemini-2.0-flash
# LITELLM_MODEL=openrouter/meta-llama/llama-3.1-70b-instruct
# LITELLM_MODEL=ollama/llama3.1

# OPENAI_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# PII redaction settings
REDACT_REPLACEMENT=[REDACTED]
DETECT_TYPES=credit_card,ssn,email,phone,address,name,account_number
